[push]
	default = current
    autoSetupRemote = true

[core]
    editor = vim
	excludesfile = ~/.gitignore

[diff]
    tool = vimdiff

[alias]
	st = status
    ci = commit
	co = checkout
    br = branch
    unstage = reset HEAD --
    last = log -1 HEAD
	b = branch
	lt = log --pretty=oneline --graph --all

[url "https://bitbucket.org/"]
    insteadOf = bb:

[url "https://github.com/"]
    insteadOf = gh:

[url "https://gist.github.com/"]
    insteadOf = gist:
[commit]
	template = ~/.git-commit-msg
	gpgSign = true
[branch "master"]
	rebase = true
[gpg]
	program = /opt/homebrew/bin/gpg
